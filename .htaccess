Options -Indexes
DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

RewriteRule ^api/ - [L]

RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ %1/ [R=301,L]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^(best-online-betting-india|yaarwin|yaarwin-login|yaarwin-register|yaarwin-app|yaarwin-withdrawal|yaarwin-review|yaarwin-game-login|aviator-betting-india|teen-patti-online|rummy-game-india|wingo-game-india|cricket-betting-india|dc-vs-csk-result-ipl-2026|srh-vs-pbks-preview-ipl-2026|srh-vs-pbks-235-4-recap-ipl-2026|fast-withdrawal-betting-india|slots-game-india|live-casino-india|andar-bahar-online|blog|guides|how-to)/?$ /page-template.php [L,QSA]
</IfModule>

<IfModule mod_headers.c>
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self' https://yaarwin.org; img-src 'self' data: https:; font-src 'self' data: https:; style-src 'self' 'unsafe-inline' https:; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; connect-src 'self' https://api.telegram.org https://static.cloudflareinsights.com; upgrade-insecure-requests"
<FilesMatch "\.(?:css|js|png|webp|jpg|jpeg|gif|svg|ico|woff2?)$">
  Header set Cache-Control "public, max-age=2592000, immutable"
</FilesMatch>
</IfModule>

<FilesMatch "\.(env|ini|log|sql|bak|config)$">
  Require all denied
</FilesMatch>
